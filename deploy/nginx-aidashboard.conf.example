# Copy to /etc/nginx/sites-available/aidashboard on the server, then:
# sudo ln -sf /etc/nginx/sites-available/aidashboard /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
#
# SSE + Next behind nginx: disable buffering so chat streams don't stall mid-reply.

server {
    listen 80;
    server_name _;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_buffering off;
        proxy_request_buffering off;
        chunked_transfer_encoding on;

        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }
}
